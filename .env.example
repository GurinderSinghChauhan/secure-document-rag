# Generate a high-entropy value for every production deployment.
# Format: {"api-key-with-at-least-32-characters":{"tenant_id":"acme-health","user_id":"admin-1","roles":["admin","clinician"]}}
TENANT_API_KEYS_JSON={"replace-with-a-real-secret-at-least-32-chars":{"tenant_id":"acme-health","user_id":"admin-1","roles":["admin"]}}
POSTGRES_PASSWORD=replace-with-a-unique-long-postgres-password
DATABASE_URL=postgresql+asyncpg://secure_rag:secure_rag@postgres:5432/secure_rag
QDRANT_URL=http://qdrant:6333
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2:3b
MAX_UPLOAD_BYTES=26214400
MAX_DOCUMENT_CHUNKS=2000
MAX_CONTEXT_CHARACTERS=24000
MIN_RETRIEVAL_SCORE=0.25
ALLOWED_HOSTS=localhost,127.0.0.1
